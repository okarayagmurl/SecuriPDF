# SecuriPDF — Ubuntu / prod ortam sablonu
# Kopyalama: cp docker/.env.ubuntu.example docker/.env
# Windows dev sablonu: docker/.env.example

ENTERA_VERSION=1.0.0
STIRLING_VERSION=0.46.2
IMAGE_TAG=1.0.0-stirling-0.46.2
STIRLING_IMAGE=docker.stirlingpdf.com/stirlingtools/stirling-pdf

HTTP_PORT=80
HTTPS_PORT=443
STIRLING_INTERNAL_PORT=8080
STIRLING_MEMORY_LIMIT=4G

# Linux deploy kullanicisi: id -u / id -g
PUID=1000
PGID=1000

UI_APPNAME=SecuriPDF
UI_HOMEDESCRIPTION=Kurumsal PDF islem platformu
UI_APPNAMENAVBAR=SecuriPDF
SYSTEM_DEFAULTLOCALE=tr-TR
LANGS=tr_TR,en_GB

DOCKER_ENABLE_SECURITY=false
SECURITY_ENABLELOGIN=false

# --- Active Directory (DUZENLEYIN) ---
LDAP_HOST=192.168.1.10
LDAP_URL=ldap://192.168.1.10:389
LDAP_BASE_DN=dc=sirket,dc=local
LDAP_USERS_DN=CN=Users,dc=sirket,dc=local
LDAP_GROUPS_DN=dc=sirket,dc=local
LDAP_BIND_DN=CN=svc-securipdf,CN=Users,dc=sirket,dc=local
LDAP_BIND_PASSWORD=CHANGE-ME
LDAP_GROUP_USER=SecuriPDF-Users
LDAP_GROUP_ADMIN=SecuriPDF-Admins
LDAP_GROUP_FILTER=(cn=SecuriPDF-*)

# --- Keycloak / OAuth (DUZENLEYIN) ---
# Ornek hostname: pdf.sirket.local
KEYCLOAK_HTTP_PORT=8090
KEYCLOAK_HOSTNAME=pdf.sirket.local
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE-ME-Strong-KcAdmin
KEYCLOAK_DB_PASSWORD=CHANGE-ME-Strong-KcDb
KEYCLOAK_PROXY=edge

OAUTH2_CLIENT_ID=securipdf
OAUTH2_CLIENT_SECRET=CHANGE-ME-Strong-OAuth2-Secret
OAUTH2_ISSUER_URL=https://pdf.sirket.local/realms/securipdf
OAUTH2_REDIRECT_URL=https://pdf.sirket.local/oauth2/callback
OAUTH2_COOKIE_SECRET=CHANGE-ME-32-Char-Hex-Secret-Min-32chars
OAUTH2_COOKIE_EXPIRE=30m
OAUTH2_GROUPS_CLAIM=realm_access.roles
OAUTH2_OIDC_AUDIENCE_CLAIM=azp

# Prod guvenlik
OAUTH2_INSECURE_ISSUER=false
OAUTH2_SKIP_DISCOVERY=false
OAUTH2_ALLOW_UNVERIFIED_EMAIL=false
OAUTH2_INSECURE_TLS=false
OAUTH2_COOKIE_SECURE=true

VAULT_MASTER_KEY=CHANGE-ME-32-Char-Vault-Master-Key!!
BREAK_GLASS_PASSWORD=CHANGE-ME-Local-Admin-Password

SYSTEM_MAXFILESIZE=500
SYSTEM_ENABLEANALYTICS=false
SYSTEM_GOOGLEVISIBILITY=false
METRICS_ENABLED=false
SHOW_SURVEY=false

CLIENT_MAX_BODY_SIZE=500M
PROXY_READ_TIMEOUT=3600
PROXY_SEND_TIMEOUT=3600
BACKUP_RETENTION_DAYS=30

# --- E-posta (Vault belge gonderimi) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.sirket.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=securipdf@sirket.local
SMTP_USE_TLS=true
SMTP_MAX_ATTACHMENT_MB=25
