# SecuriPDF — Kapali ag / lab kurulum sablonu (HTTP, IP veya FQDN)
# Kopyalama: cp docker/.env.offline.example docker/.env
# Sonra: cd docker && ./fix-access-url.sh SUNUCU_IP

ENTERA_VERSION=1.0.0
STIRLING_VERSION=0.46.2
IMAGE_TAG=1.0.0-stirling-0.46.2
STIRLING_IMAGE=docker.stirlingpdf.com/stirlingtools/stirling-pdf

HTTP_PORT=8080
HTTPS_PORT=443
STIRLING_INTERNAL_PORT=8080
STIRLING_MEMORY_LIMIT=4G

PUID=1000
PGID=1000

PUBLIC_SERVER_IP=192.168.1.100
PUBLIC_FQDN=192.168.1.100
KEYCLOAK_PUBLIC_FQDN=192.168.1.100
PUBLIC_USE_HTTPS=false

UI_APPNAME=SecuriPDF
SYSTEM_DEFAULTLOCALE=tr-TR
LANGS=tr_TR,en_GB
DOCKER_ENABLE_SECURITY=false
SECURITY_ENABLELOGIN=false

# LDAP — kurulum sonrasi Admin panelden (bos birakilabilir)
LDAP_HOST=
LDAP_URL=
LDAP_BASE_DN=
LDAP_USERS_DN=
LDAP_GROUPS_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

KEYCLOAK_HTTP_PORT=8090
KEYCLOAK_HOSTNAME=192.168.1.100
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE-ME-KcAdmin
KEYCLOAK_DB_PASSWORD=CHANGE-ME-KcDb
KEYCLOAK_PROXY=edge

OAUTH2_CLIENT_ID=securipdf
# BOS BIRAKMAYIN — bos deger oauth2-proxy 500 (unauthorized_client) verir
OAUTH2_CLIENT_SECRET=CHANGE-ME-OAuth2-Secret
OAUTH2_ISSUER_URL=http://192.168.1.100:8090/realms/securipdf
OAUTH2_REDIRECT_URL=http://192.168.1.100:8080/oauth2/callback
OAUTH2_LOGIN_URL=http://192.168.1.100:8090/realms/securipdf/protocol/openid-connect/auth?ui_locales=tr
OAUTH2_COOKIE_SECRET=CHANGE-ME-32-Char-Hex-Secret-Min-32chars
OAUTH2_COOKIE_EXPIRE=30m
OAUTH2_GROUPS_CLAIM=realm_access.roles
OAUTH2_OIDC_AUDIENCE_CLAIM=azp
OAUTH2_INSECURE_ISSUER=true
OAUTH2_SKIP_DISCOVERY=true
OAUTH2_ALLOW_UNVERIFIED_EMAIL=true
OAUTH2_INSECURE_TLS=true
OAUTH2_COOKIE_SECURE=false

VAULT_MASTER_KEY=CHANGE-ME-Vault-Master-Key-32chars!!
BREAK_GLASS_PASSWORD=CHANGE-ME-Local-Admin-Password

CLIENT_MAX_BODY_SIZE=500M
PROXY_READ_TIMEOUT=3600
PROXY_SEND_TIMEOUT=3600
BACKUP_RETENTION_DAYS=30
SMTP_ENABLED=false
