# SecuriPDF - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env

# --- Versiyonlama ---
ENTERA_VERSION=1.0.0
STIRLING_VERSION=0.46.2
IMAGE_TAG=1.0.0-stirling-0.46.2

# --- Stirling-PDF Upstream Image ---
STIRLING_IMAGE=docker.stirlingpdf.com/stirlingtools/stirling-pdf

# --- Ağ ---
HTTP_PORT=8080
HTTPS_PORT=443
STIRLING_INTERNAL_PORT=8080
# Admin paneli > Operasyon > Ortam ve erisim (varsayilan; panelden guncellenebilir)
PUBLIC_SERVER_IP=192.168.6.248
PUBLIC_FQDN=localhost
KEYCLOAK_PUBLIC_FQDN=
PUBLIC_USE_HTTPS=false

# --- Kaynak limitleri ---
STIRLING_MEMORY_LIMIT=4G

# --- Kullanıcı / İzinler (Linux) ---
PUID=1000
PGID=1000

# --- UI / Branding ---
UI_APPNAME=SecuriPDF
UI_HOMEDESCRIPTION=Kurumsal PDF işlem platformu
UI_APPNAMENAVBAR=SecuriPDF
UI_LOGOSTYLE=classic
SYSTEM_DEFAULTLOCALE=tr-TR
LANGS=tr_TR,en_GB

# --- Güvenlik (Stirling login AÇMAYIN — docs/AUTH-ARCHITECTURE.md) ---
DOCKER_ENABLE_SECURITY=false
SECURITY_ENABLELOGIN=false

# --- Active Directory (Entera test) ---
LDAP_HOST=192.168.6.10
LDAP_URL=ldap://192.168.6.10:389
LDAP_BASE_DN=dc=entera,dc=test
LDAP_USERS_DN=CN=Users,dc=entera,dc=test
# Gruplar CN=Users disinda olabilir (or. CN=SecuriPDF-Users,DC=entera,DC=test)
LDAP_GROUPS_DN=dc=entera,dc=test
LDAP_BIND_DN=CN=administrator,CN=Users,dc=entera,dc=test
LDAP_BIND_PASSWORD=q1w2e3!!!

# AD gruplari -> Keycloak rolleri (map-ad-group-roles.ps1)
LDAP_GROUP_USER=SecuriPDF-Users
LDAP_GROUP_ADMIN=SecuriPDF-Admins
LDAP_GROUP_FILTER=(cn=SecuriPDF-*)
# TEK GIRIS: http://localhost:8080  (Keycloak zorunlu)
# 4180 KAPALI — auth tasimasi sonrasi kullanilmiyor
# Baslatma:  .\up-auth.ps1   veya:
#   docker compose -f docker-compose.yml -f docker-compose.auth.yml up -d
# Keycloak:  http://SUNUCU_IP:8090  (localhost yerine IP/FQDN kullanin)
KEYCLOAK_HTTP_PORT=8090
KEYCLOAK_HOSTNAME=localhost

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=ChangeMe-KcAdmin-2026
KEYCLOAK_DB_PASSWORD=ChangeMe-KcDb-2026

OAUTH2_CLIENT_ID=securipdf
OAUTH2_CLIENT_SECRET=SecuriPDF-OAuth2-Dev-Secret-2026
# Asagidaki localhost degerlerini SUNUCU IP veya FQDN ile degistirin (hepsi tutarli olmali)
OAUTH2_ISSUER_URL=http://localhost:8090/realms/securipdf
OAUTH2_REDIRECT_URL=http://localhost:8080/oauth2/callback
# Opsiyonel — bos birakilirsa KEYCLOAK_HOSTNAME + portlardan uretilir (docker-compose.auth.yml)
# OAUTH2_LOGIN_URL=http://192.168.6.175:8090/realms/securipdf/protocol/openid-connect/auth?ui_locales=tr
OAUTH2_COOKIE_SECRET=a8f3c2e1b9d7046f5e8a1c3b7d9024e6
OAUTH2_COOKIE_EXPIRE=30m
OAUTH2_GROUPS_CLAIM=realm_access.roles
# Keycloak access token: aud=account, azp=client-id — oauth2-proxy keycloak-oidc icin azp kullanilir
OAUTH2_OIDC_AUDIENCE_CLAIM=azp
# Prod: false yapin (Faz 1 TLS sonrasi)
OAUTH2_INSECURE_ISSUER=true
OAUTH2_SKIP_DISCOVERY=true
OAUTH2_ALLOW_UNVERIFIED_EMAIL=true
OAUTH2_INSECURE_TLS=true
OAUTH2_COOKIE_SECURE=false

# Platform (Faz 3-6)
VAULT_MASTER_KEY=dev-master-key-change-in-production!!
BREAK_GLASS_PASSWORD=SecuriPDF-Local-Admin-2026
KEYCLOAK_PROXY=edge

# Faz 1 — prod intranet icin ip-whitelist.prod.conf nginx'e kopyalayin
# TLS: .\generate-tls.ps1

# --- Sistem ---
SYSTEM_MAXFILESIZE=500
SYSTEM_ENABLEANALYTICS=false
SYSTEM_GOOGLEVISIBILITY=false
SYSTEM_CUSTOMHTMLFILES=true
METRICS_ENABLED=false
SHOW_SURVEY=false
LEGAL_TERMSANDCONDITIONS=
LEGAL_PRIVACYPOLICY=

# --- Nginx ---
CLIENT_MAX_BODY_SIZE=500M
PROXY_READ_TIMEOUT=3600
PROXY_SEND_TIMEOUT=3600

# --- Yedekleme ---
BACKUP_RETENTION_DAYS=30

# --- E-posta (Vault belge gonderimi) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.sirket.local
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=securipdf@sirket.local
# starttls | ssl | none — ic ag relay icin none
SMTP_SECURITY=starttls
SMTP_AUTH_ENABLED=false
SMTP_USE_TLS=true
SMTP_MAX_ATTACHMENT_MB=25

# ENDPOINTS_TOREMOVE — sync-tools-config.py tarafından doldurulur
