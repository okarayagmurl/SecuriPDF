# SecuriPDF — Prod ortam sablonu
# Kopyalama: copy .env.prod.example .env  (mevcut .env uzerine YAZMAYIN — el ile birlestirin)

# OAuth2 — sertlestirilmis
OAUTH2_INSECURE_ISSUER=false
OAUTH2_SKIP_DISCOVERY=false
OAUTH2_ALLOW_UNVERIFIED_EMAIL=false
OAUTH2_INSECURE_TLS=false
OAUTH2_COOKIE_SECURE=true
OAUTH2_GROUPS_CLAIM=roles

# Guclu parolalar (ornek — degistirin)
KEYCLOAK_ADMIN_PASSWORD=CHANGE-ME-Strong-KcAdmin
KEYCLOAK_DB_PASSWORD=CHANGE-ME-Strong-KcDb
OAUTH2_CLIENT_SECRET=CHANGE-ME-Strong-OAuth2-Secret
OAUTH2_COOKIE_SECRET=CHANGE-ME-32-Char-Hex-Secret-Min
VAULT_MASTER_KEY=CHANGE-ME-32-Char-Vault-Master-Key!!

# TLS
HTTPS_PORT=443

# IP whitelist: apply-prod-hardening.ps1 ile ip-whitelist.prod.conf uygulanir
